<body onload="preloadImages()">
	
	<div id="container">
	  <header>	
			<img src="../Images/Logo1.png" alt="Logo1" id="logo"
				onmouseover="document.getElementById('logo').src='Images/Logo2.png'"
				onmouseout="document.getElementById('logo').src='Images/Logo1.png'">
			<img src="../Images/banner.png" alt="Banner" id="banner">
		  <nav>
			<a href="../Home.html">Home</a>
			<a href="../AboutUs.html">About Us</a>
			<a href="../Tributes.html">Tributes</a>
			<a href="../Survey.html">Survey</a>
			<a href="../Links.html">Favorites</a>
		  </nav>
		</header>

		<!-- TemplateBeginEditable name="PageContent" -->
		<section>
		  <article>
		    <div class="backstop">
		      <h1>Welcome to Extreme Honeymoons!</h1>
		      <p> If you are just getting hitched, we can help make your honeymoon outrageous.</p>
		      <p>Take a look at our Excursions and take the opportunity to complete our survey.</p>
	        </div>
		    <div class="backstop">
		      <h2>Photo Gallery</h2>
		      <img src="../Images/Thumbnails/CoupleBike2Sm.jpg" alt="Couple on Bikes" class="thumbnail"
						 onMouseOver="document.getElementById('fullsize').src='Images/Fullsize/CoupleBike2Lg.jpg'"
						 onMouseOut="document.getElementById('fullsize').src='Images/Fullsize/CoupleBike2Lg.jpg'"> <img src="../Images/Thumbnails/HeliSkiingSm.jpg" alt="Heli Skiing" class="thumbnail"
						 onMouseOver="document.getElementById('fullsize').src='Images/Fullsize/HeliSkiingLg.jpg'"
						 onMouseOut="document.getElementById('fullsize').src='Images/Fullsize/CoupleBike2Lg.jpg'"> <img src="../Images/Thumbnails/hunt3.jpg" alt="Bow Hunting" class="thumbnail"
						 onMouseOver="document.getElementById('fullsize').src='Images/Fullsize/bowhunt1.jpg'"
						 onMouseOut="document.getElementById('fullsize').src='Images/Fullsize/CoupleBike2Lg.jpg'"> <img src="../Images/Thumbnails/ScubaSmall.jpg" alt="Scuba Diving" class="thumbnail"
						 onMouseOver="document.getElementById('fullsize').src='Images/Fullsize/ScubaCoupleLg.jpg'"
						 onMouseOut="document.getElementById('fullsize').src='Images/Fullsize/CoupleBike2Lg.jpg'"> <img src="../Images/Fullsize/CoupleBike2Lg.jpg" alt="Full size photo" id="fullsize"> </div>
		    <div class="backstop"> <img src="../Images/Thumbnails/MotorcycleSm.jpg" alt="Tribute Image" id="tributeimg">
		      <h2>Featured Tribute</h2>
		      <p>Here is our lovely couple that started it all. They love living life to the 
		        fullest, and love helping others do the same. <a href="../Tributes.html">more &gt;&gt;</a></p>
	        </div>
	      </article>
	    </section>
